<% content_for :title, "SmartTrader Dashboard" %>

<div class="home-container">
  <!-- Animated Background -->
  <div class="home-background">
    <div class="home-background__gradient"></div>
    <div class="home-background__grid"></div>
  </div>

  <!-- Header -->
  <header class="home-header">
    <div class="home-header__left">
      <div class="home-logo">
        <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M14 22L16 17C17 16 19 15 22 15C25 15 27 17 28 19L30 22" stroke="url(#logoGradient)" stroke-width="2" stroke-linecap="round"/>
          <path d="M12 24L14 22L16 23L20 19L22 21" stroke="#06b6d4" stroke-width="1" stroke-linecap="round" opacity="0.6"/>
        </svg>
      </div>
      <h1 class="home-header__title">SmartTrader</h1>
    </div>
    <div class="home-header__right">
      <div class="user-profile">
        <div class="user-profile__avatar">
          <span class="user-profile__initial"><%= @current_user.name[0].upcase %></span>
        </div>
        <span class="user-profile__name"><%= @current_user.display_name %></span>
        <%= link_to logout_path, data: { turbo_method: :delete }, class: "logout-btn", title: "Sign out" do %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
          </svg>
        <% end %>
      </div>
    </div>
  </header>

  <!-- Welcome Section -->
  <section class="welcome-section">
    <div class="welcome-section__content">
      <h2 class="welcome-section__title">Welcome to SmartTrader</h2>
      <p class="welcome-section__subtitle">Everything is Agent - AI-Powered Trading Platform</p>
      <div class="welcome-section__stats">
        <div class="stat-card">
          <div class="stat-card__value">9+</div>
          <div class="stat-card__label">Core Modules</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__value">AI</div>
          <div class="stat-card__label">Powered</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__value">24/7</div>
          <div class="stat-card__label">Monitoring</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Modules Section -->
  <section class="modules-section">
    <div class="modules-section__header">
      <h2 class="modules-section__title">Core Modules</h2>
      <p class="modules-section__subtitle">Explore our AI-driven trading features</p>
    </div>

    <div class="modules-grid">
      <!-- Module 1: Trader Profile -->
      <div class="module-card" data-module="trader-profile" data-complexity="3">
        <div class="module-card__header">
          <div class="module-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </div>
          <span class="module-card__number">01</span>
        </div>
        <h3 class="module-card__title">Trader Profile</h3>
        <p class="module-card__subtitle">操盘手信息管理</p>
        <div class="module-card__tech">
          <span class="tech-badge">LLM</span>
        </div>
        <div class="module-card__complexity complexity-3"></div>
        <div class="module-card__description">
          AI 解析文字描述，自动生成操盘手性格特征、交易风格及资产配置建议
        </div>
        <div class="module-card__features">
          <span class="feature-tag">CRUD</span>
          <span class="feature-tag">AI Generate</span>
          <span class="feature-tag">Asset Allocation</span>
        </div>
        <%= link_to traders_path, class: "module-card__action module-card__action--active" do %>
          进入模块
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        <% end %>
      </div>

      <!-- Module 2: Asset Data Collection -->
      <div class="module-card" data-module="asset-data" data-complexity="3">
        <div class="module-card__header">
          <div class="module-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
            </svg>
          </div>
          <span class="module-card__number">02</span>
        </div>
        <h3 class="module-card__title">Asset Data Collection</h3>
        <p class="module-card__subtitle">资产动态信息采集</p>
        <div class="module-card__tech">
          <span class="tech-badge">MCP</span>
          <span class="tech-badge">Skills</span>
        </div>
        <div class="module-card__complexity complexity-3"></div>
        <div class="module-card__description">
          后台定时采集股票、加密货币等资产动态数据，支持 yahoo-finance 和 ccxt
        </div>
        <div class="module-card__features">
          <span class="feature-tag">Stocks</span>
          <span class="feature-tag">Crypto</span>
          <span class="feature-tag">Auto-fetch</span>
        </div>
        <button class="module-card__action" data-module="asset-data">
          Coming Soon
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </div>

      <!-- Module 3: Portfolio Dashboard -->
      <div class="module-card" data-module="portfolio" data-complexity="2">
        <div class="module-card__header">
          <div class="module-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="20" x2="12" y2="10"></line>
              <line x1="18" y1="20" x2="18" y2="4"></line>
              <line x1="6" y1="20" x2="6" y2="16"></line>
            </svg>
          </div>
          <span class="module-card__number">03</span>
        </div>
        <h3 class="module-card__title">Portfolio Dashboard</h3>
        <p class="module-card__subtitle">操盘手资产管理页面</p>
        <div class="module-card__tech">
          <span class="tech-badge">LLM</span>
        </div>
        <div class="module-card__complexity complexity-2"></div>
        <div class="module-card__description">
          显示操盘手投资组合盈亏图表，持仓详情及 AI 生成的分析报告
        </div>
        <div class="module-card__features">
          <span class="feature-tag">Charts</span>
          <span class="feature-tag">P/L View</span>
          <span class="feature-tag">AI Reports</span>
        </div>
        <button class="module-card__action" data-module="portfolio">
          Coming Soon
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </div>

      <!-- Module 4: Investment Info -->
      <div class="module-card" data-module="investment-info" data-complexity="3">
        <div class="module-card__header">
          <div class="module-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
          </div>
          <span class="module-card__number">04</span>
        </div>
        <h3 class="module-card__title">Investment Info</h3>
        <p class="module-card__subtitle">投资信息 Skill</p>
        <div class="module-card__tech">
          <span class="tech-badge">Skills</span>
        </div>
        <div class="module-card__complexity complexity-3"></div>
        <div class="module-card__description">
          获取最新投资新闻、市场分析报告和特定资产研究信息
        </div>
        <div class="module-card__features">
          <span class="feature-tag">News Feed</span>
          <span class="feature-tag">Market Reports</span>
          <span class="feature-tag">Research</span>
        </div>
        <button class="module-card__action" data-module="investment-info">
          Coming Soon
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </div>

      <!-- Module 5: Market Sentiment -->
      <div class="module-card" data-module="market-sentiment" data-complexity="3">
        <div class="module-card__header">
          <div class="module-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
              <line x1="9" y1="9" x2="9.01" y2="9"></line>
              <line x1="15" y1="9" x2="15.01" y2="9"></line>
            </svg>
          </div>
          <span class="module-card__number">05</span>
        </div>
        <h3 class="module-card__title">Market Sentiment</h3>
        <p class="module-card__subtitle">市场情绪指数</p>
        <div class="module-card__tech">
          <span class="tech-badge">CLI</span>
          <span class="tech-badge">LLM</span>
        </div>
        <div class="module-card__complexity complexity-3"></div>
        <div class="module-card__description">
          Claude Code CLI 分析市场情绪，生成恐惧贪婪指数和历史趋势图
        </div>
        <div class="module-card__features">
          <span class="feature-tag">Fear/Greed</span>
          <span class="feature-tag">Trend Chart</span>
          <span class="feature-tag">Sector Analysis</span>
        </div>
        <button class="module-card__action" data-module="market-sentiment">
          Coming Soon
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </div>

      <!-- Module 6: Auto Allocation -->
      <div class="module-card" data-module="auto-allocation" data-complexity="4">
        <div class="module-card__header">
          <div class="module-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <span class="module-card__number">06</span>
        </div>
        <h3 class="module-card__title">Auto Allocation</h3>
        <p class="module-card__subtitle">定时资产配置任务</p>
        <div class="module-card__tech">
          <span class="tech-badge">LLM</span>
          <span class="tech-badge">CLI</span>
        </div>
        <div class="module-card__complexity complexity-4"></div>
        <div class="module-card__description">
          为操盘手分配资金，根据 AI 分析动态调整资产配置策略
        </div>
        <div class="module-card__features">
          <span class="feature-tag">$100K Start</span>
          <span class="feature-tag">Dynamic</span>
          <span class="feature-tag">AI Decision</span>
        </div>
        <button class="module-card__action" data-module="auto-allocation">
          Coming Soon
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </div>

      <!-- Module 7: Performance Ranking -->
      <div class="module-card" data-module="performance" data-complexity="2">
        <div class="module-card__header">
          <div class="module-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path>
              <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path>
              <path d="M4 22h16"></path>
              <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path>
              <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path>
              <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path>
            </svg>
          </div>
          <span class="module-card__number">07</span>
        </div>
        <h3 class="module-card__title">Performance Ranking</h3>
        <p class="module-card__subtitle">资产配置盈亏排名</p>
        <div class="module-card__tech">
          <span class="tech-badge">LLM</span>
        </div>
        <div class="module-card__complexity complexity-2"></div>
        <div class="module-card__description">
          操盘手盈亏排名列表，展示收益率、夏普比率等指标和个性化分析
        </div>
        <div class="module-card__features">
          <span class="feature-tag">Leaderboard</span>
          <span class="feature-tag">Sharpe Ratio</span>
          <span class="feature-tag">AI Insights</span>
        </div>
        <button class="module-card__action" data-module="performance">
          Coming Soon
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </div>

      <!-- Module 8: Signal Plaza -->
      <div class="module-card highlight" data-module="signal-plaza" data-complexity="5">
        <div class="module-card__header">
          <div class="module-card__icon highlight-shine">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
            </svg>
          </div>
          <span class="module-card__number featured">08</span>
        </div>
        <div class="badge badge-featured">Most Complex</div>
        <h3 class="module-card__title">Signal Plaza</h3>
        <p class="module-card__subtitle">信号广场</p>
        <div class="module-card__tech">
          <span class="tech-badge">LLM</span>
          <span class="tech-badge">CLI</span>
          <span class="tech-badge">Skills</span>
        </div>
        <div class="module-card__complexity complexity-5"></div>
        <div class="module-card__description">
          AI 分析监控资产的交易信号：黄金、BTC、英伟达等，提供实时告警
        </div>
        <div class="module-card__features">
          <span class="feature-tag">Real-time</span>
          <span class="feature-tag">Alerts</span>
          <span class="feature-tag">Multi-asset</span>
        </div>
        <button class="module-card__action highlighted" data-module="signal-plaza">
          Coming Soon
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </div>

      <!-- Module 9: Investor Personas -->
      <div class="module-card" data-module="investor-personas" data-complexity="2">
        <div class="module-card__header">
          <div class="module-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <span class="module-card__number">09</span>
        </div>
        <h3 class="module-card__title">Investor Personas</h3>
        <p class="module-card__subtitle">投资人性格模板 Skill</p>
        <div class="module-card__tech">
          <span class="tech-badge">Skills</span>
        </div>
        <div class="module-card__complexity complexity-2"></div>
        <div class="module-card__description">
          巴菲特、索罗斯等著名投资人投资风格模板库，快速创建名人风格操盘手
        </div>
        <div class="module-card__features">
          <span class="feature-tag">Berkshire</span>
          <span class="feature-tag">Quant</span>
          <span class="feature-tag">20+ Legends</span>
        </div>
        <button class="module-card__action" data-module="investor-personas">
          Coming Soon
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </div>
    </div>
  </section>

  <!-- Coming Soon Section -->
  <section class="modules-section modules-section--priority-low">
    <div class="modules-section__header">
      <h2 class="modules-section__title">Low Priority Modules</h2>
      <p class="modules-section__subtitle">Additional features under development</p>
    </div>

    <div class="modules-grid modules-grid--compact">
      <!-- Module 10: Portfolio Analysis -->
      <div class="module-card compact" data-module="portfolio-analysis" data-complexity="2">
        <div class="module-card__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="2" y1="12" x2="22" y2="12"></line>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
          </svg>
        </div>
        <h4 class="module-card__title">Portfolio Analysis</h4>
        <p class="module-card__subtitle">持仓分析 Skill</p>
        <div class="module-card__complexity complexity-2"></div>
      </div>

      <!-- Module 11: Technical Indicators -->
      <div class="module-card compact" data-module="technical-indicators" data-complexity="2">
        <div class="module-card__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline>
            <polyline points="16 7 22 7 22 13"></polyline>
          </svg>
        </div>
        <h4 class="module-card__title">Technical Indicators</h4>
        <p class="module-card__subtitle">技术指标解读 Skill</p>
        <div class="module-card__complexity complexity-2"></div>
      </div>

      <!-- Module 12: Trading Strategies -->
      <div class="module-card compact" data-module="trading-strategies" data-complexity="2">
        <div class="module-card__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7"></rect>
            <rect x="14" y="3" width="7" height="7"></rect>
            <rect x="14" y="14" width="7" height="7"></rect>
            <rect x="3" y="14" width="7" height="7"></rect>
          </svg>
        </div>
        <h4 class="module-card__title">Trading Strategies</h4>
        <p class="module-card__subtitle">交易策略模板 Skill</p>
        <div class="module-card__complexity complexity-2"></div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="home-footer">
    <p class="home-footer__text">© 2026 SmartTrader. Everything is Agent.</p>
    <nav class="home-footer__links">
      <a href="#" class="home-footer__link">Documentation</a>
      <a href="#" class="home-footer__link">API</a>
      <a href="#" class="home-footer__link">Support</a>
    </nav>
  </footer>
</div>

<script type="module">
  import 'home';
</script>
