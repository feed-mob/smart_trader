<% content_for :title, "信号详情 - #{@signal.asset.symbol}" %>

<div class="signal-detail-page">
  <!-- Background -->
  <div class="signal-detail-bg">
    <div class="signal-detail-bg__gradient"></div>
    <div class="signal-detail-bg__grid"></div>
    <div class="signal-detail-bg__glow signal-detail-bg__glow--<%= @signal.signal_type %>"></div>
  </div>

  <!-- Header -->
  <header class="signal-detail-header">
    <%= link_to admin_trading_signals_path, class: "signal-back-btn" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      返回信号列表
    <% end %>
    <div class="signal-detail-header__meta">
      <span class="signal-detail-header__time">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        <%= @signal.generated_at.strftime("%Y-%m-%d %H:%M:%S") %>
      </span>
    </div>
  </header>

  <!-- Main Content -->
  <main class="signal-detail-main">
    <!-- Hero Card -->
    <section class="signal-hero signal-hero--<%= @signal.signal_type %>">
      <div class="signal-hero__bg"></div>
      <div class="signal-hero__content">
        <!-- Asset Info -->
        <div class="signal-hero__asset">
          <div class="signal-hero__symbol"><%= @signal.asset.symbol %></div>
          <div class="signal-hero__name"><%= @signal.asset.name %></div>
        </div>

        <!-- Signal Type -->
        <div class="signal-hero__signal">
          <div class="signal-type-badge-lg signal-type-badge-lg--<%= @signal.signal_type %>">
            <% if @signal.buy? %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline>
              <polyline points="16 7 22 7 22 13"></polyline>
            </svg>
            <% elsif @signal.sell? %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="22 17 13.5 8.5 8.5 13.5 2 7"></polyline>
              <polyline points="16 17 22 17 22 11"></polyline>
            </svg>
            <% else %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="8" y1="12" x2="16" y2="12"></line>
            </svg>
            <% end %>
            <span><%= @signal.signal_type_label %></span>
          </div>
        </div>

        <!-- Confidence Circle -->
        <div class="signal-hero__confidence">
          <div class="confidence-ring confidence-ring--<%= @signal.confidence_level %>">
            <svg viewBox="0 0 120 120">
              <circle class="confidence-ring__bg" cx="60" cy="60" r="54" />
              <circle class="confidence-ring__progress" cx="60" cy="60" r="54"
                      style="stroke-dasharray: <%= @signal.confidence_percentage * 3.39 %>, 339;
                             stroke: <%= @signal.buy? ? '#10b981' : @signal.sell? ? '#ef4444' : '#94a3b8' %>;" />
            </svg>
            <div class="confidence-ring__center">
              <span class="confidence-ring__value"><%= @signal.confidence_percentage %></span>
              <span class="confidence-ring__unit">%</span>
            </div>
          </div>
          <div class="confidence-ring__label">置信度</div>
        </div>
      </div>
    </section>

    <!-- Reasoning Section -->
    <section class="signal-card">
      <div class="signal-card__header">
        <div class="signal-card__icon signal-card__icon--cyan">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
        </div>
        <h2 class="signal-card__title">信号解读</h2>
      </div>
      <div class="signal-card__body">
        <p class="signal-reasoning"><%= @signal.reasoning %></p>
      </div>
    </section>

    <!-- Key Factors Section -->
    <% if @signal.key_factors.present? %>
    <section class="signal-card">
      <div class="signal-card__header">
        <div class="signal-card__icon signal-card__icon--yellow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
          </svg>
        </div>
        <h2 class="signal-card__title">关键驱动因子</h2>
      </div>
      <div class="signal-card__body">
        <div class="key-factors-grid">
          <% @signal.key_factors.each do |factor| %>
          <div class="key-factor-chip">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            <span><%= factor %></span>
          </div>
          <% end %>
        </div>
      </div>
    </section>
    <% end %>

    <!-- Risk Warning Section -->
    <% if @signal.risk_warning.present? %>
    <section class="signal-card signal-card--warning">
      <div class="signal-card__header">
        <div class="signal-card__icon signal-card__icon--orange">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
            <line x1="12" y1="9" x2="12" y2="13"></line>
            <line x1="12" y1="17" x2="12.01" y2="17"></line>
          </svg>
        </div>
        <h2 class="signal-card__title">风险提示</h2>
      </div>
      <div class="signal-card__body">
        <p class="signal-warning"><%= @signal.risk_warning %></p>
      </div>
    </section>
    <% end %>

    <!-- Factor Snapshot Section -->
    <% if @signal.factor_snapshot.present? %>
    <section class="signal-card">
      <div class="signal-card__header">
        <div class="signal-card__icon signal-card__icon--purple">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7" rx="1"></rect>
            <rect x="14" y="3" width="7" height="7" rx="1"></rect>
            <rect x="14" y="14" width="7" height="7" rx="1"></rect>
            <rect x="3" y="14" width="7" height="7" rx="1"></rect>
          </svg>
        </div>
        <h2 class="signal-card__title">因子快照</h2>
        <span class="signal-card__badge">生成时刻数据</span>
      </div>
      <div class="signal-card__body">
        <div class="factor-snapshot-cards">
          <% @signal.factor_snapshot.each do |code, data| %>
          <div class="factor-snapshot-card">
            <div class="factor-snapshot-card__header">
              <span class="factor-snapshot-card__name"><%= data["name"] %></span>
              <span class="factor-snapshot-card__weight">权重 <%= (data["weight"].to_f * 100).round(0) %>%</span>
            </div>
            <div class="factor-snapshot-card__value <%= factor_value_class(data["normalized_value"]) %>">
              <% if data["normalized_value"].present? %>
                <%= data["normalized_value"].to_f.round(2) %>
              <% else %>
                N/A
              <% end %>
            </div>
            <% if data["percentile"].present? %>
            <div class="factor-snapshot-card__percentile">
              <div class="percentile-bar">
                <div class="percentile-bar__fill" style="width: <%= data["percentile"].to_f %>%"></div>
              </div>
              <span>百分位 <%= data["percentile"].to_f.round(1) %>%</span>
            </div>
            <% end %>
          </div>
          <% end %>
        </div>
      </div>
    </section>
    <% end %>

    <!-- Actions -->
    <section class="signal-actions">
      <%= link_to matrix_admin_factor_definitions_path, class: "signal-action-btn signal-action-btn--secondary" do %>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7" rx="1"></rect>
          <rect x="14" y="3" width="7" height="7" rx="1"></rect>
          <rect x="14" y="14" width="7" height="7" rx="1"></rect>
          <rect x="3" y="14" width="7" height="7" rx="1"></rect>
        </svg>
        查看因子矩阵
      <% end %>
      <%= button_to generate_admin_trading_signals_path(asset_id: @signal.asset_id), method: :post, class: "signal-action-btn signal-action-btn--primary" do %>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 2v6h-6"></path>
          <path d="M3 12a9 9 0 0 1 15-6.7L21 8"></path>
          <path d="M3 22v-6h6"></path>
          <path d="M21 12a9 9 0 0 1-15 6.7L3 16"></path>
        </svg>
        重新生成信号
      <% end %>
    </section>
  </main>
</div>
