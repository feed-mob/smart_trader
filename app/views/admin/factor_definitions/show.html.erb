<% content_for :title, "#{@factor.name} - 因子详情 - SmartTrader" %>

<div class="factor-detail-container">
  <!-- Header -->
  <header class="factor-detail-header">
    <div class="factor-detail-header__left">
      <%= link_to admin_factor_definitions_path, class: "factor-back-link" do %>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="factor-back-link__icon">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        <span>返回列表</span>
      <% end %>
    </div>
    <div class="factor-detail-header__right">
      <%= link_to "编辑因子", edit_admin_factor_definition_path(@factor), class: "btn btn-primary" %>
    </div>
  </header>

  <!-- Main Content -->
  <main class="factor-detail-main">
    <% if notice.present? %>
      <div class="alert alert-success">
        <%= notice %>
      </div>
    <% end %>

    <div class="factor-detail-grid">
      <!-- Left Column: Basic Info -->
      <div class="factor-detail-card">
        <div class="factor-detail-card__header">
          <div class="factor-detail-card__icon factor-detail-card__icon--<%= @factor.category %>">
            <% case @factor.category %>
            <% when 'momentum' %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                <polyline points="17 6 23 6 23 12"></polyline>
              </svg>
            <% when 'risk' %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
              </svg>
            <% when 'volume' %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="3" y1="9" x2="21" y2="9"></line>
                <line x1="9" y1="21" x2="9" y2="9"></line>
              </svg>
            <% when 'sentiment' %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
                <line x1="9" y1="9" x2="9.01" y2="9"></line>
                <line x1="15" y1="9" x2="15.01" y2="9"></line>
              </svg>
            <% when 'technical' %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="20" x2="12" y2="10"></line>
                <line x1="18" y1="20" x2="18" y2="4"></line>
                <line x1="6" y1="20" x2="6" y2="16"></line>
              </svg>
            <% else %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
              </svg>
            <% end %>
          </div>
          <div class="factor-detail-card__title-group">
            <h1 class="factor-detail-card__title"><%= @factor.name %></h1>
            <span class="factor-detail-card__code"><%= @factor.code %></span>
          </div>
          <span class="factor-detail-card__status <%= @factor.active? ? 'active' : 'inactive' %>">
            <%= @factor.display_status %>
          </span>
        </div>

        <div class="factor-detail-card__body">
          <div class="factor-info-grid">
            <div class="factor-info-item">
              <span class="factor-info-item__label">分类</span>
              <span class="factor-info-item__value"><%= @factor.display_category %></span>
            </div>
            <div class="factor-info-item">
              <span class="factor-info-item__label">默认权重</span>
              <span class="factor-info-item__value"><%= @factor.display_weight %></span>
            </div>
            <div class="factor-info-item">
              <span class="factor-info-item__label">更新频率</span>
              <span class="factor-info-item__value">每 <%= @factor.update_frequency %> 分钟</span>
            </div>
            <div class="factor-info-item">
              <span class="factor-info-item__label">计算方法</span>
              <span class="factor-info-item__value"><%= @factor.calculation_method %></span>
            </div>
          </div>

          <div class="factor-description">
            <h3 class="factor-description__title">因子描述</h3>
            <p class="factor-description__text"><%= @factor.description %></p>
          </div>
        </div>
      </div>

      <!-- Right Column: Parameters -->
      <div class="factor-detail-card">
        <div class="factor-detail-card__header">
          <h2 class="factor-detail-card__section-title">参数配置</h2>
        </div>

        <div class="factor-detail-card__body">
          <% if @factor.parameters.present? %>
            <div class="factor-params">
              <% @factor.parameters.each do |key, value| %>
                <div class="factor-param-item">
                  <span class="factor-param-item__label"><%= key.to_s.humanize %></span>
                  <span class="factor-param-item__value"><%= value %></span>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="factor-empty-text">暂无参数配置</p>
          <% end %>
        </div>
      </div>

      <!-- Calculation Formula Card -->
      <div class="factor-detail-card factor-detail-card--full">
        <div class="factor-detail-card__header">
          <h2 class="factor-detail-card__section-title">计算说明</h2>
        </div>

        <div class="factor-detail-card__body">
          <div class="factor-formula">
            <% case @factor.code %>
            <% when 'momentum' %>
              <div class="factor-formula__item">
                <h4>计算公式</h4>
                <code>Momentum = (当前价格 - N日前价格) / N日前价格</code>
              </div>
              <div class="factor-formula__item">
                <h4>评分规则</h4>
                <ul>
                  <li>涨幅 0-50% → 评分 0 到 +1</li>
                  <li>跌幅 0-50% → 评分 0 到 -1</li>
                </ul>
              </div>
            <% when 'volatility' %>
              <div class="factor-formula__item">
                <h4>计算公式</h4>
                <code>Volatility = √(Σ(日收益率 - 平均收益率)² / (N-1))</code>
              </div>
              <div class="factor-formula__item">
                <h4>评分规则</h4>
                <ul>
                  <li>低波动 → 正分（风险低）</li>
                  <li>高波动 → 负分（风险高）</li>
                </ul>
              </div>
            <% when 'beta' %>
              <div class="factor-formula__item">
                <h4>计算公式</h4>
                <code>Beta = Cov(资产收益率, 基准收益率) / Var(基准收益率)</code>
              </div>
              <div class="factor-formula__item">
                <h4>基准选择</h4>
                <ul>
                  <li>加密货币：BTC</li>
                  <li>股票：S&P 500 (SPY)</li>
                  <li>商品：GLD</li>
                </ul>
              </div>
              <div class="factor-formula__item">
                <h4>评分规则</h4>
                <ul>
                  <li>Beta ≈ 1 → 正分（与市场同步）</li>
                  <li>Beta 偏离1 → 负分（波动异常）</li>
                </ul>
              </div>
            <% when 'volume_ratio' %>
              <div class="factor-formula__item">
                <h4>计算公式</h4>
                <code>VR = 上涨日平均成交量 / 下跌日平均成交量</code>
              </div>
              <div class="factor-formula__item">
                <h4>评分规则</h4>
                <ul>
                  <li>VR > 1.5 → 正分（大资金流入）</li>
                  <li>VR < 0.8 → 负分（资金流出）</li>
                  <li>0.8-1.5 → 中性</li>
                </ul>
              </div>
            <% when 'trend' %>
              <div class="factor-formula__item">
                <h4>计算公式</h4>
                <code>Trend = 线性回归斜率 (N日价格序列)</code>
              </div>
              <div class="factor-formula__item">
                <h4>评分规则</h4>
                <ul>
                  <li>斜率 > 0 → 正分（上升趋势）</li>
                  <li>斜率 < 0 → 负分（下降趋势）</li>
                </ul>
              </div>
            <% when 'sentiment' %>
              <div class="factor-formula__item">
                <h4>计算方式</h4>
                <p>基于市场涨跌幅分布计算，反映市场整体情绪</p>
              </div>
            <% else %>
              <p class="factor-empty-text">暂无计算说明</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
