<% content_for :title, "因子管理 - SmartTrader" %>

<div class="factors-container">
  <!-- Animated Background -->
  <div class="factors-background">
    <div class="factors-background__gradient"></div>
    <div class="factors-background__grid"></div>
  </div>

  <!-- Header -->
  <header class="factors-header">
    <div class="factors-header__left">
      <%= link_to root_path, class: "factors-logo" do %>
        <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M14 22L16 17C17 16 19 15 22 15C25 15 27 17 28 19L30 22" stroke="url(#logoGradient)" stroke-width="2" stroke-linecap="round"/>
          <path d="M12 24L14 22L16 23L20 19L22 21" stroke="#06b6d4" stroke-width="1" stroke-linecap="round" opacity="0.6"/>
        </svg>
      <% end %>
      <h1 class="factors-header__title">因子管理</h1>
      <span class="factors-header__count">
        共 <%= @factors.count %> 个因子 · 总权重 <%= (@factors.sum(:weight) * 100).round(0) %>%
      </span>
    </div>
    <div class="factors-header__right">
      <div class="factors-header__btn-group">
        <%= link_to matrix_admin_factor_definitions_path, class: "factors-header__matrix-btn" do %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"></rect>
            <rect x="14" y="3" width="7" height="7"></rect>
            <rect x="14" y="14" width="7" height="7"></rect>
            <rect x="3" y="14" width="7" height="7"></rect>
          </svg>
          <span>因子矩阵</span>
        <% end %>
        <%= link_to correlations_admin_factor_definitions_path, class: "factors-header__matrix-btn" do %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 20V10"></path>
            <path d="M12 20V4"></path>
            <path d="M6 20v-6"></path>
          </svg>
          <span>相关性</span>
        <% end %>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="factors-main">
    <% if notice.present? %>
      <div class="alert alert-success">
        <%= notice %>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="alert alert-error">
        <%= alert %>
      </div>
    <% end %>

    <div class="factors-grid factors-grid--compact">
      <% @factors.each do |factor| %>
        <div class="factor-card" data-active="<%= factor.active? %>">
          <div class="factor-card__header">
            <div class="factor-card__icon factor-card__icon--<%= factor.category %>">
              <% case factor.category %>
              <% when 'momentum' %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
                  <polyline points="17 6 23 6 23 12"></polyline>
                </svg>
              <% when 'risk' %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
                </svg>
              <% when 'volume' %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                  <line x1="3" y1="9" x2="21" y2="9"></line>
                  <line x1="9" y1="21" x2="9" y2="9"></line>
                </svg>
              <% when 'sentiment' %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"></circle>
                  <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
                  <line x1="9" y1="9" x2="9.01" y2="9"></line>
                  <line x1="15" y1="9" x2="15.01" y2="9"></line>
                </svg>
              <% when 'technical' %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="20" x2="12" y2="10"></line>
                  <line x1="18" y1="20" x2="18" y2="4"></line>
                  <line x1="6" y1="20" x2="6" y2="16"></line>
                </svg>
              <% else %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="12" y1="8" x2="12" y2="12"></line>
                  <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
              <% end %>
            </div>
            <span class="factor-card__status <%= factor.active? ? 'active' : 'inactive' %>">
              <%= factor.display_status %>
            </span>
          </div>

          <h3 class="factor-card__name"><%= factor.name %></h3>
          <p class="factor-card__code"><%= factor.code %> · <%= factor.display_category %></p>

          <p class="factor-card__description">
            <%= truncate(factor.description, length: 50) %>
          </p>

          <div class="factor-card__stats">
            <div class="factor-card__stat">
              <span class="factor-card__stat-label">权重</span>
              <span class="factor-card__stat-value"><%= factor.display_weight %></span>
            </div>
            <div class="factor-card__stat">
              <span class="factor-card__stat-label">周期</span>
              <span class="factor-card__stat-value"><%= factor.calculation_days %>日</span>
            </div>
          </div>

          <div class="factor-card__actions">
            <%= link_to "详情", admin_factor_definition_path(factor), class: "btn btn-secondary btn-sm" %>
            <%= button_to factor.active? ? "禁用" : "启用",
                toggle_admin_factor_definition_path(factor),
                method: :post,
                class: factor.active? ? "btn btn-danger btn-sm" : "btn btn-primary btn-sm" %>
          </div>
        </div>
      <% end %>
    </div>
  </main>
</div>
