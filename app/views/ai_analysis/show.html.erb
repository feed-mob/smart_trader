<% content_for :title, "AI 分析结果" %>

<div class="ai-terminal">
  <!-- Scanline Effect -->
  <div class="ai-terminal__scanline"></div>

  <!-- Grid Background -->
  <div class="ai-terminal__grid"></div>

  <!-- Header -->
  <header class="ai-header">
    <div class="ai-header__left">
      <%= link_to root_path, class: "ai-logo" do %>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      <% end %>
      <div class="ai-header__title-group">
        <h1 class="ai-header__title">ANALYSIS RESULT</h1>
        <span class="ai-header__status">
          <span class="status-dot status-dot--complete"></span>
          COMPLETE
        </span>
      </div>
    </div>
    <div class="ai-header__right">
      <%= link_to new_ai_analysis_path, class: "ai-header__btn" do %>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
          <path d="M12 4v16m8-8H4"/>
        </svg>
        NEW ANALYSIS
      <% end %>
    </div>
  </header>

  <main class="ai-main ai-main--result">
    <% if @error %>
      <!-- Error State -->
      <section class="ai-panel ai-panel--error">
        <div class="ai-error">
          <div class="ai-error__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 8v4m0 4h.01"/>
            </svg>
          </div>
          <div class="ai-error__content">
            <h2 class="ai-error__title">ANALYSIS FAILED</h2>
            <p class="ai-error__message"><%= @error %></p>
            <% if @backtrace %>
              <div class="ai-error__trace">
                <% @backtrace.each do |line| %>
                  <div><%= line %></div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </section>
    <% elsif @result %>
      <!-- Stats Bar -->
      <section class="ai-stats">
        <div class="ai-stat">
          <span class="ai-stat__value"><%= @assets.length %></span>
          <span class="ai-stat__label">Assets</span>
        </div>
        <div class="ai-stat ai-stat--buy">
          <span class="ai-stat__value"><%= @result[:signals]&.dig(:buy) || 0 %></span>
          <span class="ai-stat__label">Buy</span>
        </div>
        <div class="ai-stat ai-stat--sell">
          <span class="ai-stat__value"><%= @result[:signals]&.dig(:sell) || 0 %></span>
          <span class="ai-stat__label">Sell</span>
        </div>
        <div class="ai-stat ai-stat--hold">
          <span class="ai-stat__value"><%= @result[:signals]&.dig(:hold) || 0 %></span>
          <span class="ai-stat__label">Hold</span>
        </div>
        <div class="ai-stat">
          <span class="ai-stat__value"><%= @analysis_type == 'full' ? 'FULL' : 'QUICK' %></span>
          <span class="ai-stat__label">Mode</span>
        </div>
      </section>

      <div class="ai-result-grid">
        <!-- Logs Panel -->
        <section class="ai-panel ai-panel--logs">
          <div class="ai-panel__header">
            <span class="ai-panel__icon">◉</span>
            <h2 class="ai-panel__title">EXECUTION LOG</h2>
            <span class="ai-panel__badge"><%= @logs&.length || 0 %> entries</span>
          </div>
          <div class="ai-log-container">
            <% if @logs && @logs.any? %>
              <% @logs.each do |log| %>
                <div class="ai-log-entry">
                  <span class="ai-log-entry__marker">›</span>
                  <span class="ai-log-entry__text"><%= log %></span>
                </div>
              <% end %>
            <% else %>
              <div class="ai-log-empty">No logs available</div>
            <% end %>
          </div>
        </section>

        <!-- Recommendation Panel -->
        <% if @result[:recommendation] %>
          <% rec = @result[:recommendation] %>
          <section class="ai-panel ai-panel--recommendation">
            <div class="ai-panel__header">
              <span class="ai-panel__icon">◈</span>
              <h2 class="ai-panel__title">AI RECOMMENDATION</h2>
            </div>

            <div class="ai-rec-content">
              <!-- Market Analysis -->
              <div class="ai-rec-section">
                <h3 class="ai-rec-section__title">MARKET ANALYSIS</h3>
                <p class="ai-rec-section__text"><%= rec[:market_analysis] || "No analysis available" %></p>
              </div>

              <!-- Strategy Selection -->
              <div class="ai-rec-meta">
                <div class="ai-rec-meta__item">
                  <span class="ai-rec-meta__label">Strategy</span>
                  <span class="ai-rec-meta__value ai-rec-meta__value--highlight"><%= rec[:selected_strategy] || "normal" %></span>
                </div>
                <div class="ai-rec-meta__item">
                  <span class="ai-rec-meta__label">Allocations</span>
                  <span class="ai-rec-meta__value"><%= rec[:allocations]&.length || 0 %> assets</span>
                </div>
              </div>

              <!-- Summary -->
              <% if rec[:summary] %>
                <div class="ai-rec-section ai-rec-section--summary">
                  <h3 class="ai-rec-section__title">SUMMARY</h3>
                  <p class="ai-rec-section__text"><%= rec[:summary] %></p>
                </div>
              <% end %>

              <!-- Allocations Table -->
              <% if rec[:allocations]&.any? %>
                <div class="ai-rec-allocations">
                  <h3 class="ai-rec-section__title">ALLOCATION BREAKDOWN</h3>
                  <table class="ai-table">
                    <thead>
                      <tr>
                        <th>Asset</th>
                        <th>Weight</th>
                        <th>Signal</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% rec[:allocations].each do |allocation| %>
                        <tr>
                          <td class="ai-table__symbol"><%= allocation[:symbol] %></td>
                          <td class="ai-table__weight"><%= number_to_percentage(allocation[:weight] * 100, precision: 1) %></td>
                          <td>
                            <span class="ai-signal ai-signal--<%= allocation[:signal]&.downcase %>">
                              <%= allocation[:signal] %>
                            </span>
                          </td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              <% end %>

              <!-- Detailed Reasoning -->
              <% if rec[:detailed_reasoning].present? %>
                <div class="ai-rec-section ai-rec-section--detailed">
                  <h3 class="ai-rec-section__title">DETAILED ANALYSIS</h3>
                  <div class="ai-rec-section__content">
                    <%= simple_format(h(rec[:detailed_reasoning]), class: "ai-rec-section__text") %>
                  </div>
                </div>
              <% end %>

              <!-- Cash Reserve -->
              <% if rec[:cash_reserve] %>
                <div class="ai-rec-meta">
                  <div class="ai-rec-meta__item">
                    <span class="ai-rec-meta__label">Cash Reserve</span>
                    <span class="ai-rec-meta__value"><%= rec[:cash_reserve][:percent] %>% ($<%= number_with_delimiter(rec[:cash_reserve][:amount_usd].to_i) %>)</span>
                  </div>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>
      </div>

      <!-- Action Bar -->
      <div class="ai-action-bar">
        <%= link_to new_ai_analysis_path, class: "ai-btn ai-btn--primary" do %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
            <path d="M12 4v16m8-8H4"/>
          </svg>
          NEW ANALYSIS
        <% end %>
        <%= link_to traders_path, class: "ai-btn ai-btn--secondary" do %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
            <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
          TRADERS
        <% end %>
      </div>
    <% end %>
  </main>
</div>

<style>
/* AI Terminal Base */
.ai-terminal {
  min-height: 100vh;
  background: linear-gradient(135deg, #0a0f1a 0%, #0d1520 50%, #0a1018 100%);
  color: #e2e8f0;
  font-family: 'Inter', -apple-system, sans-serif;
  position: relative;
  overflow: hidden;
}

.ai-terminal__scanline {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0, 255, 200, 0.01) 2px,
    rgba(0, 255, 200, 0.01) 4px
  );
  pointer-events: none;
  z-index: 1000;
}

.ai-terminal__grid {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image:
    linear-gradient(rgba(6, 182, 212, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(6, 182, 212, 0.03) 1px, transparent 1px);
  background-size: 50px 50px;
  pointer-events: none;
}

/* Header */
.ai-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 2rem;
  border-bottom: 1px solid rgba(6, 182, 212, 0.2);
  background: rgba(10, 15, 26, 0.8);
  backdrop-filter: blur(10px);
}

.ai-header__left {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.ai-logo {
  width: 48px;
  height: 48px;
  background: linear-gradient(135deg, rgba(6, 182, 212, 0.2), rgba(6, 182, 212, 0.05));
  border: 1px solid rgba(6, 182, 212, 0.3);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #06b6d4;
}

.ai-logo svg {
  width: 28px;
  height: 28px;
}

.ai-header__title-group {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.ai-header__title {
  font-size: 1.25rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  color: #f1f5f9;
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
}

.ai-header__status {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  color: #22c55e;
  font-family: 'JetBrains Mono', monospace;
}

.status-dot {
  width: 8px;
  height: 8px;
  background: #22c55e;
  border-radius: 50%;
  animation: pulse 2s infinite;
}

.status-dot--complete {
  background: #22c55e;
}

@keyframes pulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
  50% { opacity: 0.8; box-shadow: 0 0 0 8px rgba(34, 197, 94, 0); }
}

.ai-header__btn {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1rem;
  background: rgba(6, 182, 212, 0.1);
  border: 1px solid rgba(6, 182, 212, 0.3);
  border-radius: 6px;
  color: #06b6d4;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  font-family: 'JetBrains Mono', monospace;
  text-decoration: none;
  transition: all 0.2s;
}

.ai-header__btn:hover {
  background: rgba(6, 182, 212, 0.2);
  border-color: #06b6d4;
}

/* Main Content - Result */
.ai-main--result {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  padding: 1.5rem 2rem;
  max-width: 1400px;
  margin: 0 auto;
}

/* Stats Bar */
.ai-stats {
  display: flex;
  gap: 1px;
  background: rgba(6, 182, 212, 0.1);
  border-radius: 8px;
  overflow: hidden;
}

.ai-stat {
  flex: 1;
  padding: 1rem 1.5rem;
  background: rgba(15, 23, 42, 0.8);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
}

.ai-stat__value {
  font-size: 1.5rem;
  font-weight: 700;
  font-family: 'JetBrains Mono', monospace;
  color: #f1f5f9;
}

.ai-stat__label {
  font-size: 0.625rem;
  color: #64748b;
  letter-spacing: 0.15em;
  font-family: 'JetBrains Mono', monospace;
}

.ai-stat--buy .ai-stat__value { color: #22c55e; }
.ai-stat--sell .ai-stat__value { color: #ef4444; }
.ai-stat--hold .ai-stat__value { color: #eab308; }

/* Result Grid */
.ai-result-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}

@media (max-width: 1024px) {
  .ai-result-grid {
    grid-template-columns: 1fr;
  }
}

/* Panels */
.ai-panel {
  background: rgba(15, 23, 42, 0.6);
  border: 1px solid rgba(6, 182, 212, 0.15);
  border-radius: 12px;
  overflow: hidden;
}

.ai-panel__header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem 1.25rem;
  background: rgba(6, 182, 212, 0.05);
  border-bottom: 1px solid rgba(6, 182, 212, 0.1);
}

.ai-panel__icon {
  color: #06b6d4;
  font-size: 1rem;
}

.ai-panel__title {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  color: #94a3b8;
  font-family: 'JetBrains Mono', monospace;
}

.ai-panel__badge {
  margin-left: auto;
  font-size: 0.625rem;
  padding: 0.25rem 0.5rem;
  background: rgba(6, 182, 212, 0.15);
  color: #06b6d4;
  border-radius: 4px;
  font-family: 'JetBrains Mono', monospace;
  letter-spacing: 0.05em;
}

/* Log Panel */
.ai-panel--logs {
  display: flex;
  flex-direction: column;
}

.ai-log-container {
  flex: 1;
  max-height: 400px;
  overflow-y: auto;
  padding: 1rem;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  line-height: 1.8;
}

.ai-log-entry {
  display: flex;
  gap: 0.5rem;
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  transition: background 0.15s;
}

.ai-log-entry:hover {
  background: rgba(6, 182, 212, 0.05);
}

.ai-log-entry__marker {
  color: #06b6d4;
  flex-shrink: 0;
}

.ai-log-entry__text {
  color: #94a3b8;
  word-break: break-all;
}

.ai-log-empty {
  color: #475569;
  font-style: italic;
  padding: 2rem;
  text-align: center;
}

/* Recommendation Panel */
.ai-rec-content {
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.ai-rec-section {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.ai-rec-section__title {
  font-size: 0.625rem;
  color: #64748b;
  letter-spacing: 0.15em;
  font-family: 'JetBrains Mono', monospace;
}

.ai-rec-section__text {
  font-size: 0.875rem;
  color: #e2e8f0;
  line-height: 1.6;
}

.ai-rec-section--summary {
  padding: 1rem;
  background: rgba(6, 182, 212, 0.05);
  border-left: 3px solid #06b6d4;
  border-radius: 0 8px 8px 0;
}

.ai-rec-section--detailed {
  padding: 1rem;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 8px;
  max-height: 300px;
  overflow-y: auto;
}

.ai-rec-section__content {
  font-size: 0.8rem;
  color: #cbd5e1;
  line-height: 1.8;
}

.ai-rec-section__content p {
  margin-bottom: 0.75rem;
}

.ai-rec-meta {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

.ai-rec-meta__item {
  padding: 0.75rem 1rem;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.ai-rec-meta__label {
  font-size: 0.625rem;
  color: #64748b;
  letter-spacing: 0.1em;
  font-family: 'JetBrains Mono', monospace;
}

.ai-rec-meta__value {
  font-size: 0.875rem;
  color: #f1f5f9;
  font-family: 'JetBrains Mono', monospace;
}

.ai-rec-meta__value--highlight {
  color: #06b6d4;
}

/* Allocations Table */
.ai-rec-allocations {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.ai-table {
  width: 100%;
  border-collapse: collapse;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
}

.ai-table th {
  text-align: left;
  padding: 0.5rem 0.75rem;
  color: #64748b;
  font-weight: 600;
  letter-spacing: 0.1em;
  border-bottom: 1px solid rgba(6, 182, 212, 0.1);
}

.ai-table td {
  padding: 0.75rem;
  border-bottom: 1px solid rgba(6, 182, 212, 0.05);
}

.ai-table__symbol {
  color: #f1f5f9;
  font-weight: 600;
}

.ai-table__weight {
  color: #06b6d4;
}

/* Signal Badges */
.ai-signal {
  display: inline-flex;
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
  font-size: 0.625rem;
  font-weight: 600;
  letter-spacing: 0.05em;
}

.ai-signal--buy {
  background: rgba(34, 197, 94, 0.15);
  color: #22c55e;
}

.ai-signal--sell {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

.ai-signal--hold {
  background: rgba(234, 179, 8, 0.15);
  color: #eab308;
}

/* Action Bar */
.ai-action-bar {
  display: flex;
  justify-content: center;
  gap: 1rem;
  padding: 1rem 0;
}

.ai-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.875rem 1.5rem;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  font-family: 'JetBrains Mono', monospace;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
  text-decoration: none;
}

.ai-btn--primary {
  background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%);
  color: #0a0f1a;
  border: none;
  box-shadow: 0 4px 20px rgba(6, 182, 212, 0.3);
}

.ai-btn--primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 30px rgba(6, 182, 212, 0.4);
}

.ai-btn--secondary {
  background: transparent;
  color: #94a3b8;
  border: 1px solid rgba(6, 182, 212, 0.3);
}

.ai-btn--secondary:hover {
  border-color: #06b6d4;
  color: #06b6d4;
}

/* Error State */
.ai-panel--error {
  padding: 2rem;
}

.ai-error {
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
}

.ai-error__icon {
  width: 48px;
  height: 48px;
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ef4444;
  flex-shrink: 0;
}

.ai-error__icon svg {
  width: 24px;
  height: 24px;
}

.ai-error__content {
  flex: 1;
}

.ai-error__title {
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: #fca5a5;
  font-family: 'JetBrains Mono', monospace;
  margin-bottom: 0.5rem;
}

.ai-error__message {
  color: #94a3b8;
  margin-bottom: 1rem;
}

.ai-error__trace {
  padding: 1rem;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  color: #64748b;
  line-height: 1.6;
}

/* Scrollbar */
.ai-log-container::-webkit-scrollbar {
  width: 6px;
}

.ai-log-container::-webkit-scrollbar-track {
  background: rgba(0, 0, 0, 0.2);
}

.ai-log-container::-webkit-scrollbar-thumb {
  background: rgba(6, 182, 212, 0.3);
  border-radius: 3px;
}

.ai-log-container::-webkit-scrollbar-thumb:hover {
  background: rgba(6, 182, 212, 0.5);
}
</style>
